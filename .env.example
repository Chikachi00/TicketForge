# TicketForge local development defaults.
# These credentials are for local Docker Compose only.

POSTGRES_DB=ticketforge
POSTGRES_USER=ticketforge
POSTGRES_PASSWORD=ticketforge_dev

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ticketforge
SPRING_DATASOURCE_USERNAME=ticketforge
SPRING_DATASOURCE_PASSWORD=ticketforge_dev
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SERVER_PORT=8080

# Local-only simulated payment callback secret. Do not reuse in production.
TICKETFORGE_PAYMENT_CALLBACK_SECRET=ticketforge-local-dev-secret
